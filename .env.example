# ============================================================
# Synapse — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (main AI — required) ───────────────────────────
# Get from: console.anthropic.com → API Keys
# Used for all chat, planning, and project decomposition (Claude Sonnet)
# Portrait updates use Claude Haiku automatically (same key)
EXPO_PUBLIC_ANTHROPIC_KEY=sk-ant-...

# ── OpenAI (optional — voice only) ───────────────────────────
# Only needed if you want voice input (Whisper transcription)
# Get from: platform.openai.com → API Keys
EXPO_PUBLIC_OPENAI_KEY=sk-...
